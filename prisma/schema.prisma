generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Event {
  id             String          @id @default(cuid())
  title          String
  description    String?
  danceStyles    String[]
  venue          String
  address        String
  city           String
  latitude       Float?
  longitude      Float?
  startTime      DateTime
  endTime        DateTime
  imageUrl       String?
  ticketUrl      String?
  price          String?
  status         EventStatus     @default(PENDING_APPROVAL)
  isRecurring    Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organizerId    String
  organizer      User            @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  instances      EventInstance[]
  recurrenceRule RecurrenceRule?

  @@index([city])
  @@index([organizerId])
  @@index([startTime])
  @@index([status])
}

model EventInstance {
  id            String   @id @default(cuid())
  startTime     DateTime
  endTime       DateTime
  isCancelled   Boolean  @default(false)
  isModified    Boolean  @default(false)
  modifiedTitle String?
  modifiedVenue String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  eventId       String
  Event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([startTime])
}

model NotificationLog {
  id      String   @id @default(cuid())
  email   String
  type    String
  eventId String?
  sentAt  DateTime @default(now())
  status  String

  @@index([email])
  @@index([sentAt])
}

model RecurrenceRule {
  id         String              @id @default(cuid())
  frequency  RecurrenceFrequency
  interval   Int                 @default(1)
  daysOfWeek Int[]
  monthlyPattern   MonthlyPattern @default(BY_DATE)
  monthlyDayOfWeek Int?
  monthlyWeeks     Int[]
  until      DateTime?
  count      Int?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  eventId    String              @unique
  Event      Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id                 String   @id @default(cuid())
  email              String   @unique
  danceStyles        String[]
  cities             String[]
  emailNotifications Boolean  @default(true)
  weeklyDigest       Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  userId             String?
  User               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?
  role          UserRole       @default(USER)
  verified      Boolean        @default(false)
  bio           String?
  phone         String?
  website       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Account       Account[]
  events        Event[]
  Session       Session[]
  Subscription  Subscription[]

  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  CANCELLED
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum MonthlyPattern {
  BY_DATE
  BY_WEEKDAY
}

enum UserRole {
  USER
  ORGANIZER
  ADMIN
}
